rules_version = '2';

// =====================================================================================
// KRBL Pricing Simulator — Firestore Security Rules
// =====================================================================================
// The Scenario Library is a SHARED library: every user who opens the dashboard must be
// able to read and write the same "scenarios" collection (the app has no Firebase Auth
// sign-in — the login screen is a client-side mock gate only). These rules therefore
// grant open read/write access to the "scenarios" collection, and deny everything else.
//
// NOTE (security): because there is no authentication, anyone who has the site's Firebase
// config can read/write these documents. That is intentional for this shared-library use
// case. If you later add Firebase Authentication, tighten the `allow` conditions below to
// e.g. `if request.auth != null` (any signed-in user) or restrict by domain/custom claims.
// =====================================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // Shared Scenario Library — readable and writable by every visitor.
    match /scenarios/{scenarioId} {
      allow read, write: if true;
    }

    // Lock down everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}